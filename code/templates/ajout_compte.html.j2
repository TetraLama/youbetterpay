{% extends 'base.html.j2' %}

{% block header %}
  <h1>{% block title %}Ajout Compte{% endblock %}</h1>
{% endblock %}

{% block content %}
  <form method="post">
    <label for="nom_compte">Nom Compte</label>
    <input name="nom_compte" id="nom_compte" value="{{ request.form['nom_compte'] }}" required>
    <input type="submit" value="Save">
  </form>
{% endblock %}